# ═══════════════════════════════════════════════════════════════════
# Bee v4.0 — Complete Environment Variable Reference
# Copy to agent/.env on VPS. NEVER commit .env!
# ═══════════════════════════════════════════════════════════════════

# --- Required (agent won't start without these) ---
DEEPSEEK_API_KEY=
CLICKUP_API_TOKEN=
BEE_BRAIN_PATH=/var/www/bee-brain

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                    # Comma-separated authorized chat IDs

# --- Google OAuth ---
GOOGLE_TOKEN_PATH=/var/www/bee-brain/agent/token.json

# --- Vault REST API (port 3003) ---
VAULT_API_KEY=                       # API key for vault REST API auth

# --- Bee Website (blaze-post.com) ---
BEE_SITE_URL=https://blaze-post.com
CRON_SECRET=                         # Vercel cron auth secret
RESEND_API_KEY=                      # For email reports (Resend.com)
CONTACT_NOTIFICATION_EMAIL=jonathanperlin@gmail.com

# --- ClickUp List IDs (have defaults in code, override if needed) ---
CLICKUP_TEAM_ID=90182449313
CLICKUP_PORTFOLIO_LIST_ID=901816399997
CLICKUP_BLOG_LIST_ID=901816400000
# CLICKUP_LEADS_LIST_ID=901816199661
# CLICKUP_ACTIVE_CLIENTS_LIST_ID=901816199662
# CLICKUP_REVENUE_LIST_ID=901816199664

# --- Web App (Next.js) ---
# DEEPSEEK_API_KEY is shared with agent (line 7) — same key for both
MONGODB_URI=                         # MongoDB connection string
AUTH_SECRET=                         # NextAuth secret (openssl rand -base64 32)
GOOGLE_CLIENT_ID=                    # Google OAuth client ID
GOOGLE_CLIENT_SECRET=                # Google OAuth client secret
NEXTAUTH_URL=                        # Canonical app URL (e.g. https://bee-ai-app.vercel.app)
ADMIN_EMAIL=                         # Admin email for full Bee personality

# --- PayPal ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=        # PayPal app client ID (public)
PAYPAL_CLIENT_ID=                    # PayPal app client ID (server)
PAYPAL_CLIENT_SECRET=                # PayPal app secret
PAYPAL_WEBHOOK_ID=                   # PayPal webhook ID for verification
NEXT_PUBLIC_PAYPAL_PRO_PLAN_ID=      # PayPal subscription plan ID for Pro tier

# --- Infrastructure ---
VPS_IP=65.109.230.136
VPS_USER=root
CONTACT_EMAIL=contact@workitu.com
